# Required environment variables for the daily-notifications Edge Function.
# These are NOT loaded from this file at runtime — Supabase Edge Functions
# read env vars from the project's "Function secrets" settings. This file
# only documents which vars the function expects.
#
# Populate via:
#   supabase secrets set SUPABASE_URL=... SUPABASE_SERVICE_ROLE_KEY=...
#
# SUPABASE_URL is the project URL (https://<ref>.supabase.co).
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS so the function can insert
# notifications on behalf of any user. NEVER expose this in client code.

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
